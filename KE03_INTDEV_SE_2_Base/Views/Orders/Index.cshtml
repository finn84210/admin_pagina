@model KE03_INTDEV_SE_2_Base.ViewModels.OrderHistoryViewModel

@{
    ViewData["Title"] = "Orderhistorie";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Orderhistorie</h1>
        <p class="text-muted mb-0">Alle orders van alle klanten in een overzicht.</p>
    </div>
    <div class="admin-actions">
        <a asp-action="Active" class="btn btn-primary">Actieve orders</a>
        <span class="badge bg-secondary fs-6 align-self-center">@Model.TotalOrders orders</span>
    </div>
</div>

<form asp-action="Index" method="get" class="border rounded-2 p-3 mb-4 bg-light">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="CustomerId" class="form-label">Klant</label>
            <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select">
                <option value="">Alle klanten</option>
            </select>
        </div>
        <div class="col-md-3">
            <label asp-for="SearchTerm" class="form-label">Zoeken</label>
            <input asp-for="SearchTerm" class="form-control" placeholder="Ordernr, klant of adres" />
        </div>
        <div class="col-md-2">
            <label asp-for="DateFrom" class="form-label">Vanaf</label>
            <input asp-for="DateFrom" type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="DateTo" class="form-label">Tot en met</label>
            <input asp-for="DateTo" type="date" class="form-control" />
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-fill">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </div>
</form>

@if (!Model.Orders.Any())
{
    <div class="alert alert-info">
        Er zijn geen orders gevonden voor deze filters.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Ordernummer</th>
                    <th>Orderdatum</th>
                    <th>Klant</th>
                    <th>Adres</th>
                    <th>Status klant</th>
                    <th>Orderstatus</th>
                    <th>Bezorger</th>
                    <th>Bron</th>
                    <th>Producten</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.OrderDate.ToString("dd-MM-yyyy")</td>
                        <td>@order.Customer.Name</td>
                        <td>@order.Customer.Address</td>
                        <td>
                            @if (order.Customer.Active)
                            {
                                <span class="badge bg-success">Actief</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactief</span>
                            }
                        </td>
                        <td>@order.Status</td>
                        <td>@(string.IsNullOrWhiteSpace(order.DeliveryPerson) ? "-" : order.DeliveryPerson)</td>
                        <td>@order.Source</td>
                        <td>
                            @if (order.Products.Any())
                            {
                                @string.Join(", ", order.Products.Select(product => product.Name))
                            }
                            else
                            {
                                <span class="text-muted">Geen producten gekoppeld</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
